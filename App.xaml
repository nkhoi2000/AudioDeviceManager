<Application x:Class="AudioDeviceManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFF3F6FA" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#FFF7F9FC" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FF132238" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FF536273" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF1E6FD9" />
        <SolidColorBrush x:Key="AccentBorderBrush" Color="#FF1E6FD9" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#FF0C8A60" />
        <SolidColorBrush x:Key="SuccessBorderBrush" Color="#FF0C8A60" />
        <SolidColorBrush x:Key="ControlForegroundBrush" Color="#FF132238" />
        <SolidColorBrush x:Key="ListBackgroundBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="StatusBarBrush" Color="#FFFFFFFF" />
    </Application.Resources>
</Application>
