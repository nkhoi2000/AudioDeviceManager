<Window x:Class="AudioDeviceManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Audio Device Manager"
        Height="640"
        Width="1080"
        MinHeight="580"
        MinWidth="960"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#FFF3F6FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Margin="24"
                Padding="24"
                Background="White"
                CornerRadius="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="#FF132238"
                               Text="Manage audio devices on this PC" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="15"
                               Foreground="#FF536273"
                               Text="Browse active input and output devices, switch the default device, and adjust volume." />
                </StackPanel>

                <Button Grid.Column="1"
                        MinWidth="120"
                        Padding="18,10"
                        Background="#FF1E6FD9"
                        Foreground="White"
                        BorderBrush="#FF1E6FD9"
                        Click="RefreshButton_OnClick"
                        Content="Refresh" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,12,0"
                    Padding="20"
                    Background="White"
                    CornerRadius="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,16">
                        <TextBlock FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#FF132238"
                                   Text="Sound Output" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#FF536273"
                                   Text="Active playback devices connected to this machine." />
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ListBox x:Name="PlaybackDevicesListBox"
                                 DisplayMemberPath="Summary"
                                 SelectionChanged="PlaybackDevicesListBox_OnSelectionChanged" />

                        <StackPanel Grid.Row="1" Margin="0,16,0,0">
                            <TextBlock x:Name="PlaybackSelectedName"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#FF132238"
                                       Text="No device selected" />
                            <TextBlock x:Name="PlaybackStatusText"
                                       Margin="0,4,0,0"
                                       Foreground="#FF536273"
                                       Text="Status: -" />
                            <TextBlock x:Name="PlaybackVolumeText"
                                       Margin="0,12,0,6"
                                       Foreground="#FF132238"
                                       Text="Volume: 0%" />
                            <Slider x:Name="PlaybackVolumeSlider"
                                    Minimum="0"
                                    Maximum="100"
                                    IsEnabled="False"
                                    ValueChanged="PlaybackVolumeSlider_OnValueChanged" />
                            <WrapPanel Margin="0,12,0,0">
                                <Button MinWidth="160"
                                        Margin="0,0,12,0"
                                        Padding="16,8"
                                        Background="#FF0C8A60"
                                        Foreground="White"
                                        BorderBrush="#FF0C8A60"
                                        Click="SetPlaybackDefaultButton_OnClick"
                                        Content="Set as Default" />
                                <CheckBox x:Name="PlaybackMuteCheckBox"
                                          VerticalAlignment="Center"
                                          IsEnabled="False"
                                          Checked="PlaybackMuteCheckBox_OnChanged"
                                          Unchecked="PlaybackMuteCheckBox_OnChanged"
                                          Content="Mute selected device" />
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="12,0,0,0"
                    Padding="20"
                    Background="White"
                    CornerRadius="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,16">
                        <TextBlock FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#FF132238"
                                   Text="Sound Input" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#FF536273"
                                   Text="Active microphones and recording devices connected to this machine." />
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ListBox x:Name="RecordingDevicesListBox"
                                 DisplayMemberPath="Summary"
                                 SelectionChanged="RecordingDevicesListBox_OnSelectionChanged" />

                        <StackPanel Grid.Row="1" Margin="0,16,0,0">
                            <TextBlock x:Name="RecordingSelectedName"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#FF132238"
                                       Text="No device selected" />
                            <TextBlock x:Name="RecordingStatusText"
                                       Margin="0,4,0,0"
                                       Foreground="#FF536273"
                                       Text="Status: -" />
                            <TextBlock x:Name="RecordingVolumeText"
                                       Margin="0,12,0,6"
                                       Foreground="#FF132238"
                                       Text="Volume: 0%" />
                            <Slider x:Name="RecordingVolumeSlider"
                                    Minimum="0"
                                    Maximum="100"
                                    IsEnabled="False"
                                    ValueChanged="RecordingVolumeSlider_OnValueChanged" />
                            <WrapPanel Margin="0,12,0,0">
                                <Button MinWidth="160"
                                        Margin="0,0,12,0"
                                        Padding="16,8"
                                        Background="#FF0C8A60"
                                        Foreground="White"
                                        BorderBrush="#FF0C8A60"
                                        Click="SetRecordingDefaultButton_OnClick"
                                        Content="Set as Default" />
                                <CheckBox x:Name="RecordingMuteCheckBox"
                                          VerticalAlignment="Center"
                                          IsEnabled="False"
                                          Checked="RecordingMuteCheckBox_OnChanged"
                                          Unchecked="RecordingMuteCheckBox_OnChanged"
                                          Content="Mute selected device" />
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <StatusBar Grid.Row="2" Background="White">
            <StatusBarItem>
                <TextBlock x:Name="LastRefreshTextBlock" Text="Device list has not been refreshed yet." />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
